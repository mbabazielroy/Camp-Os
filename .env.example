# Supabase project credentials (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI API key, used server-side only for categorizing emails and drafting replies
OPENAI_API_KEY=
# Optional: override the model (defaults to gpt-4o-mini)
# OPENAI_MODEL=

# Optional: Gmail integration (Google Cloud Console -> OAuth 2.0 credentials).
# Add <your-app-url>/api/gmail/callback as an authorized redirect URI.
# Scopes used: gmail.readonly + gmail.compose (drafts only - the app can never send).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
